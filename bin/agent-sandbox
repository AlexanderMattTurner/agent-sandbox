#!/usr/bin/env bash
# agent-sandbox — run an untrusted Workload in a hardware-isolated,
# name-level-allowlist-firewalled, ephemeral sandbox with a tamper-evident egress log.
#
# Usage: agent-sandbox run <workload.json> | gc [--dry-run] | down <project>
#
# The launcher reads the Workload record (schema/workload.schema.json), selects a
# runtime via the backend ladder (fail-closed), allocates a subnet, then brings up the
# firewall + workload stack and execs the workload's entrypoint. Nothing here assumes
# what the workload is — what runs is entirely the Workload's business.
set -Eeuo pipefail

_AS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib/msg.bash disable=SC1091
source "$_AS_DIR/lib/msg.bash"
# shellcheck source=lib/backend.bash disable=SC1091
source "$_AS_DIR/lib/backend.bash"
# shellcheck source=lib/sandbox-net.bash disable=SC1091
source "$_AS_DIR/lib/sandbox-net.bash"
# shellcheck source=lib/stack.bash disable=SC1091
source "$_AS_DIR/lib/stack.bash"

usage() {
  cat >&2 <<'EOF'
Usage: agent-sandbox run [--extra-compose FILE]... [--reseed] <workload.json>
       agent-sandbox prewarm [--extra-compose FILE]... <workload.json>
       agent-sandbox expand <host>[:ro|rw] [--project NAME]
       agent-sandbox gc [--dry-run]
       agent-sandbox down <project>

Run a Workload (see schema/workload.schema.json) in an isolated, egress-restricted,
ephemeral sandbox. The launcher selects a runtime, allocates a subnet, brings up the
name-level-allowlist firewall, waits for its health, then execs the workload.

  --extra-compose FILE   Merge FILE (repeatable, in order) after the library's compose
                         file set on every compose invocation of the session — the seam
                         for consumer-owned companion services and service extensions.
  --reseed               When re-attaching to a stopped persistent session (workload
                         session_id + ephemeral:false), DISCARD its seeded workspace and
                         re-seed from the current checkout. Destructive, per-invocation.

A workload with `session_id` gets the deterministic compose project name
agent-sandbox-<session_id>; running it again against its stopped stack re-attaches
(same containers/volumes, seed skipped; docs/usage.md "Persistent sessions"). A
workload with `resume_from` starts FRESH, seeded to reproduce where that prior
session left off, with its exported audit log mounted read-only for continuity.

`prewarm` runs the multi-second bring-up ahead of time and leaves the stack up as
an adoptable spare (an empty, verified workspace behind a healthy firewall). A
later `run` whose boot-shaping spec matches (image digests, runtime, allowlist,
user/hardener/audit/backend, compose file set) adopts the spare — seeding into
the already-running container and skipping the cold boot; any mismatch or hiccup
falls back to a cold boot. Only seed-mode, ephemeral runs without
session_id/resume_from adopt. Bind mode (workspace_mount) can't be prewarmed.

`expand` widens a RUNNING session's egress allowlist by one host without resetting
the firewall (default access ro = GET/HEAD only). The grant is session-scoped; make
it permanent in the Workload record's egress_allowlist. With several sessions up,
name one via --project (or AGENT_SANDBOX_PROJECT_NAME).

gc prunes stale sandbox networks (no live containers), reclaiming dead sessions'
subnets, reaps prewarm spares older than AGENT_SANDBOX_PREWARM_MAX_AGE seconds
(default 86400; spares whose spec no longer matches anything simply age out —
adoption's hash equality already routes around them), and removes prewarm claims
whose owning process died; --dry-run previews what a real run would remove. down
tears down one session's stack by compose project name — containers, networks
AND volumes — and fails loud if any volume survives.

Environment: AGENT_SANDBOX_PROJECT_NAME pins the compose project name (default: a
random per-session name) so consumer lifecycle tooling can find the stack by label.
AGENT_SANDBOX_PREWARM_MAX_AGE tunes gc's spare reaping age (seconds).
EOF
}

# require_field FILE JQ_FILTER NAME — read a required Workload field, failing loud when
# absent/empty so a malformed record is rejected before anything is launched.
require_field() {
  local file="$1" filter="$2" name="$3" val
  val="$(jq -r "$filter // empty" "$file")"
  [[ -n "$val" ]] || {
    as_error "workload is missing the required field '$name'"
    return 1
  }
  printf '%s' "$val"
}

# cmd_run <workload.json> — the launch sequence. Each step fails closed: a malformed
# record, an unusable runtime, or a missing firewall stack refuses the launch rather
# than proceeding into a half-isolated state.
cmd_run() {
  # Flag parse is fail-closed like the field checks below: an --extra-compose that
  # doesn't name a readable file refuses the launch (a consumer overlay silently
  # dropped from the file set would boot the stack without its companion services).
  local -a extra_compose=()
  local workload="" reseed=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
    --reseed)
      reseed=1
      shift
      ;;
    --extra-compose)
      [[ -n "${2:-}" ]] || {
        as_error "--extra-compose needs a file argument"
        return 1
      }
      [[ -f "$2" ]] || {
        as_error "extra compose file not found: $2"
        return 1
      }
      extra_compose+=("$2")
      shift 2
      ;;
    -*)
      as_error "unknown option for run: $1"
      usage
      return 1
      ;;
    *)
      if [[ -n "$workload" ]]; then
        as_error "run takes exactly one workload file (got '$workload' and '$1')"
        return 1
      fi
      workload="$1"
      shift
      ;;
    esac
  done
  [[ -n "$workload" ]] || {
    as_error "no workload file given"
    usage
    return 1
  }
  _validate_workload_record "$workload" || return 1

  local backend
  backend="$(jq -r '.backend // "local"' "$workload")"

  # 1. Select the runtime via the backend ladder — fail-closed if it isn't usable.
  local runtime
  runtime="$(backend_select_runtime "$backend")" || return 1
  as_info "sandbox: image=$(jq -r '.image' "$workload") runtime=$runtime backend=$backend"

  # 2. Allocate a per-session subnet (firewall .2, workload .3) under a file lock.
  export_sandbox_subnet
  as_info "network: $SANDBOX_SUBNET (firewall $SANDBOX_IP)"

  # 3. Bring up the firewall + workload stack, seed, exec the entrypoint, extract,
  #    tear down (stack.bash). The compose stack (sandbox/docker-compose.yml +
  #    init-firewall) is the behavioural boundary; refuse loudly if this build
  #    doesn't carry it rather than run the workload un-firewalled.
  local compose
  compose="$(_resolve_compose)" || return 1
  # --reseed rides to stack_run's re-attach path as an exported per-invocation flag
  # (stack_run's positional tail is the open-ended extra-compose list).
  AGENT_SANDBOX_RESEED="$reseed"
  export AGENT_SANDBOX_RESEED
  stack_run "$workload" "$compose" "$runtime" ${extra_compose[@]+"${extra_compose[@]}"}
}

# _resolve_compose — print the compose stack's path (AGENT_SANDBOX_COMPOSE points
# an operator at an alternate stack), failing loud when it is absent: no compose
# file means no egress boundary, so nothing may launch.
_resolve_compose() {
  local compose="${AGENT_SANDBOX_COMPOSE:-$_AS_DIR/../sandbox/docker-compose.yml}"
  [[ -f "$compose" ]] || {
    as_error "the firewall+workload compose stack ($compose) is not present in this build — refusing to launch a workload without the egress boundary"
    return 1
  }
  printf '%s\n' "$compose"
}

# _validate_workload_record <workload.json> — the fail-closed Workload record gate
# shared by `run` and `prewarm`: file/JSON validity, the required contract fields,
# and every runtime mirror of the schema's shape constraints. Refuses before
# anything is launched.
_validate_workload_record() {
  local workload="$1"
  [[ -f "$workload" ]] || {
    as_error "workload file not found: $workload"
    return 1
  }
  jq -e . "$workload" >/dev/null 2>&1 || {
    as_error "workload file is not valid JSON: $workload"
    return 1
  }

  # Validate the required contract fields up front (image, entrypoint, egress_allowlist,
  # ephemeral). egress_allowlist must be present (even if empty is a deliberate choice);
  # entrypoint must be a non-empty argv.
  local image
  image="$(require_field "$workload" '.image' image)" || return 1
  jq -e '.entrypoint | type == "array" and length > 0' "$workload" >/dev/null || {
    as_error "workload.entrypoint must be a non-empty array (the argv to exec)"
    return 1
  }
  jq -e 'has("egress_allowlist") and (.egress_allowlist | type == "array")' "$workload" >/dev/null || {
    as_error "workload.egress_allowlist must be present (a list of hostnames; [] to allow none)"
    return 1
  }
  jq -e 'has("ephemeral") and (.ephemeral | type == "boolean")' "$workload" >/dev/null || {
    as_error "workload.ephemeral must be present (true/false)"
    return 1
  }
  # Each entry is a hostname string (rw — full access) or {host, access: ro|rw}
  # (the object form opts a host down to GET/HEAD-only).
  # One physical line per jq: kcov's DEBUG trap only marks a command's starting line, so a
  # multi-line jq leaves its continuation lines forever "uncovered" though the command ran.
  jq -e '[.egress_allowlist[]? | (type == "string") or (type == "object" and (.host | type == "string") and ((.access // "rw") == "ro" or (.access // "rw") == "rw"))] | all' "$workload" >/dev/null || {
    as_error "each workload.egress_allowlist entry must be a hostname string or {host, access: \"ro\"|\"rw\"}"
    return 1
  }
  # Reject an IP in the allowlist: enforcement is NAME-level at the proxy, and an IP
  # entry would silently never match (or invite an iptables-allowlist mistake).
  if jq -e '[.egress_allowlist[]? | if type == "object" then .host else . end | select(test("^[0-9]+\\.[0-9]+\\.[0-9]+\\.[0-9]+$"))] | length > 0' "$workload" >/dev/null; then
    as_error "workload.egress_allowlist must contain HOSTNAMES, not IPs — the allowlist is enforced by name at the forward proxy"
    return 1
  fi

  # secret_env is delivered as files named /run/secrets/<name> inside the container, so
  # a name is a path component: reject anything outside a strict env-var-shaped charset
  # before launch (a `../`-shaped name must never reach the delivery exec).
  if jq -e 'has("secret_env")' "$workload" >/dev/null; then
    jq -e '.secret_env | type == "object" and ([.[] | type == "string"] | all)' "$workload" >/dev/null || {
      as_error "workload.secret_env must be a name -> value object of string values"
      return 1
    }
    # \A/\z, not ^/$: Oniguruma's $ matches BEFORE a string-final newline, so a
    # ^…$ test would accept "NAME\n" — a name is a /run/secrets path component
    # and must be anchored against the true ends of the string.
    jq -e '.secret_env | keys | all(test("\\A[A-Za-z_][A-Za-z0-9_]*\\z"))' "$workload" >/dev/null || {
      as_error "workload.secret_env names must match ^[A-Za-z_][A-Za-z0-9_]*\$ — each becomes a file at /run/secrets/<name>"
      return 1
    }
  fi

  # session_id / resume_from become compose project names (label filters, volume name
  # prefixes), so both are gated by the schema's strict compose-safe charset at runtime
  # too — a shell-metacharacter-shaped id must never reach a docker filter string.
  if jq -e 'has("session_id")' "$workload" >/dev/null; then
    jq -e '.session_id | type == "string" and test("\\A[a-z0-9][a-z0-9_-]{0,40}\\z")' "$workload" >/dev/null || {
      as_error "workload.session_id must match ^[a-z0-9][a-z0-9_-]{0,40}\$ — it becomes the compose project name agent-sandbox-<session_id>"
      return 1
    }
  fi
  if jq -e 'has("resume_from")' "$workload" >/dev/null; then
    jq -e '.resume_from | type == "string" and test("\\A[a-z0-9][a-z0-9_-]{0,40}\\z")' "$workload" >/dev/null || {
      as_error "workload.resume_from must match ^[a-z0-9][a-z0-9_-]{0,40}\$ — it names a prior session_id"
      return 1
    }
    jq -e 'has("seed_from_git")' "$workload" >/dev/null || {
      as_error "workload.resume_from requires seed_from_git — a resumed session replays the prior work onto a freshly seeded workspace"
      return 1
    }
    jq -e '.resume_from != .session_id' "$workload" >/dev/null || {
      as_error "workload.resume_from must name a DIFFERENT session than session_id — a session cannot resume itself"
      return 1
    }
  fi

  # Bind mode (workspace_mount) and seed mode (seed_from_git) are mutually exclusive:
  # bind writes land directly on the host, seed writes are quarantined onto a review
  # branch — a record carrying both has no coherent write path, so refuse loudly
  # rather than silently pick a precedence.
  if jq -e 'has("workspace_mount") and has("seed_from_git")' "$workload" >/dev/null; then
    as_error "workload sets BOTH workspace_mount (bind mode: writes land directly on the host) AND seed_from_git (seed mode: writes are quarantined onto a review branch) — the modes are mutually exclusive; pick one (see docs/bind-mode.md)"
    return 1
  fi
  # Bind mode: validate the host source before anything is launched (stack.bash).
  if jq -e 'has("workspace_mount")' "$workload" >/dev/null; then
    stack_validate_workspace_mount "$workload" || return 1
  fi

  # overmount_paths is the sole kernel-enforced guard in bind mode, so a malformed
  # value must refuse rather than degrade: a non-array (or non-string entry) would
  # make overmount_paths_for's jq iteration error out and yield ZERO guard paths,
  # silently handing over a fully-writable host bind.
  if jq -e 'has("overmount_paths")' "$workload" >/dev/null; then
    jq -e '.overmount_paths | type == "array" and ([.[] | type == "string" and length > 0] | all)' "$workload" >/dev/null || {
      as_error "workload.overmount_paths must be an array of non-empty relative path strings (e.g. [\".git/hooks\", \"node_modules\"])"
      return 1
    }
  fi
}

# cmd_prewarm <workload.json> — bring a stack up to just before the entrypoint
# exec and leave it running as an adoptable spare (see stack_prewarm). Shares
# cmd_run's record gate, then refuses the fields a spare can never satisfy:
# workspace_mount (a bind source is baked at container create, so a bind spare is
# never generically adoptable) and session_id/resume_from (deterministic-identity
# sessions always cold-boot). env/secret_env are accepted but NOT baked — both
# are delivered at adoption exec time.
cmd_prewarm() {
  local -a extra_compose=()
  local workload=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
    --extra-compose)
      [[ -n "${2:-}" ]] || {
        as_error "--extra-compose needs a file argument"
        return 1
      }
      [[ -f "$2" ]] || {
        as_error "extra compose file not found: $2"
        return 1
      }
      extra_compose+=("$2")
      shift 2
      ;;
    -*)
      as_error "unknown option for prewarm: $1"
      usage
      return 1
      ;;
    *)
      if [[ -n "$workload" ]]; then
        as_error "prewarm takes exactly one workload file (got '$workload' and '$1')"
        return 1
      fi
      workload="$1"
      shift
      ;;
    esac
  done
  [[ -n "$workload" ]] || {
    as_error "no workload file given"
    usage
    return 1
  }
  _validate_workload_record "$workload" || return 1
  if jq -e 'has("workspace_mount")' "$workload" >/dev/null; then
    as_error "prewarm refuses workspace_mount — a bind source is baked at container create, so a bind-mode spare could only ever serve that one path; prewarm seed-shaped workloads instead"
    return 1
  fi
  if jq -e 'has("session_id") or has("resume_from")' "$workload" >/dev/null; then
    as_error "prewarm refuses session_id/resume_from — deterministic-identity sessions always cold-boot (their kept volumes and manifests assume a stack the serving launch created)"
    return 1
  fi

  local backend
  backend="$(jq -r '.backend // "local"' "$workload")"
  local runtime
  runtime="$(backend_select_runtime "$backend")" || return 1
  as_info "prewarm: image=$(jq -r '.image' "$workload") runtime=$runtime backend=$backend"
  export_sandbox_subnet
  as_info "network: $SANDBOX_SUBNET (firewall $SANDBOX_IP)"
  local compose
  compose="$(_resolve_compose)" || return 1
  stack_prewarm "$workload" "$compose" "$runtime" ${extra_compose[@]+"${extra_compose[@]}"}
}

# cmd_expand HOST[:ro|rw] [--project NAME] — widen a running session's firewall
# allowlist live. Resolves the session's firewall container by its compose labels and
# execs the in-container writer (sandbox/expand-allowlist.bash), which validates the
# domain, records it in the tmpfs overlay, and reloads dnsmasq/squid. Fails closed at
# every step: no host, a bad access tier, no (or an ambiguous) firewall container, or
# a failed in-container apply all refuse rather than half-widen.
cmd_expand() {
  local project="${AGENT_SANDBOX_PROJECT_NAME:-}" spec=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
    --project)
      [[ -n "${2:-}" ]] || {
        as_error "--project needs a compose project name"
        return 1
      }
      project="$2"
      shift 2
      ;;
    *)
      [[ -z "$spec" ]] || {
        as_error "expand takes exactly one <host>[:ro|rw] (got '$spec' and '$1')"
        return 1
      }
      spec="$1"
      shift
      ;;
    esac
  done
  [[ -n "$spec" ]] || {
    as_error "no host given"
    usage
    return 1
  }
  local host="$spec" access="ro"
  if [[ "$spec" == *:* ]]; then
    host="${spec%%:*}"
    access="${spec##*:}"
  fi
  [[ -n "$host" ]] || {
    as_error "empty host in '$spec'"
    return 1
  }
  [[ "$access" == "ro" || "$access" == "rw" ]] || {
    as_error "invalid access '$access' in '$spec' (expected ro or rw)"
    return 1
  }

  # The session's firewall container carries compose's own service/project labels
  # (stack.bash launches project agent-sandbox-<id>); resolve it by those so the exec
  # can never land in an unrelated container.
  local -a filter=(--filter label=com.docker.compose.service=firewall)
  [[ -n "$project" ]] && filter+=(--filter "label=com.docker.compose.project=$project")
  local cids
  cids="$(docker ps -q "${filter[@]}")" || {
    as_error "could not list containers — is the docker daemon running?"
    return 1
  }
  [[ -n "$cids" ]] || {
    as_error "no running firewall container found${project:+ for project $project} — nothing to expand into (is a sandbox session up?)"
    return 1
  }
  [[ "$(wc -l <<<"$cids")" -le 1 ]] || {
    as_error "several sessions have a running firewall — name one with --project NAME (or AGENT_SANDBOX_PROJECT_NAME)"
    return 1
  }
  docker exec "$cids" expand-allowlist.bash "$host:$access" || {
    as_error "live allowlist expansion failed inside the firewall container (see its output above)"
    return 1
  }
}

# cmd_gc [--dry-run] — prune stale sandbox networks (no live containers), reap
# over-age prewarm spares and dead prewarm claims (prewarm_gc). --dry-run
# previews what a real run would remove.
cmd_gc() {
  case "${1:-}" in
  --dry-run)
    GC_DRY_RUN=1 prune_stale_sandbox_networks
    GC_DRY_RUN=1 prewarm_gc
    ;;
  "")
    prune_stale_sandbox_networks
    prewarm_gc
    ;;
  *)
    as_error "unknown gc option: $1"
    usage
    return 1
    ;;
  esac
}

# cmd_down <project> — tear down one session's stack by compose project name:
# containers, networks AND volumes. Fails loud when there is nothing to tear down
# (a typo'd project must not look like a clean teardown) and when any volume
# survives, so "down" can never silently mean "still persisted".
cmd_down() {
  local project="${1:-}" containers volumes
  [[ -n "$project" ]] || {
    as_error "no compose project given"
    usage
    return 1
  }
  containers="$(docker ps -aq --filter "label=com.docker.compose.project=$project")"
  volumes="$(docker volume ls -q --filter "label=com.docker.compose.project=$project")"
  if [[ -z "$containers" && -z "$volumes" ]]; then
    as_error "nothing to tear down: no containers or volumes belong to compose project $project"
    return 1
  fi
  docker compose -p "$project" down --volumes --timeout 30 || {
    as_error "teardown failed (compose project $project) — session containers/volumes may survive"
    return 1
  }
  stack_verify_no_volumes "$project"
}

main() {
  case "${1:-}" in
  run)
    shift
    cmd_run "$@"
    ;;
  prewarm)
    shift
    cmd_prewarm "$@"
    ;;
  expand)
    shift
    cmd_expand "$@"
    ;;
  gc)
    shift
    cmd_gc "$@"
    ;;
  down)
    shift
    cmd_down "$@"
    ;;
  -h | --help | "")
    usage
    ;;
  *)
    as_error "unknown command: $1"
    usage
    return 1
    ;;
  esac
}

main "$@"
